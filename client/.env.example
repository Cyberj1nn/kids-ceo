# URL Robokassa Invoice-виджета для лендинга English Lessons.
# В настройках самого виджета в кабинете Robokassa прописаны SuccessURL2 и FailURL2,
# которые ведут на /api/payments/robokassa/{success,fail} — там сервер пишет payment
# и шлёт письмо со ссылкой на материалы.
VITE_ROBOKASSA_INVOICE_URL=https://auth.robokassa.ru/merchant/Invoice/mT1I4fhMA0y8oBdIuToPdQ

# Необязательно: тестовый виджет Robokassa с мелкой суммой.
# Если задан — в футере /english_lessons появляется маленькая ссылка «🧪 Тестовая оплата».
# Нужен для проверки end-to-end (оплата → письмо с Drive-ссылкой) без использования тестового режима магазина.
# VITE_ROBOKASSA_TEST_INVOICE_URL=https://auth.robokassa.ru/merchant/Invoice/xxxxxxxx
