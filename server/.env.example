# ===== Server =====
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ===== PostgreSQL =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kids_ceo
DB_USER=postgres
DB_PASSWORD=

# ===== Robokassa (для API-fallback подтягивания email, если SuccessURL2 его не содержит) =====
# Логин магазина в ЛК Robokassa (название магазина латиницей)
ROBOKASSA_MERCHANT_LOGIN=
# Пароль #2 из раздела «Технические настройки» магазина
ROBOKASSA_PASSWORD_2=

# ===== JWT =====
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== SMTP (локальный Postfix на сервере kids-ceo.ru) =====
# В проде: localhost:25, без аутентификации (Postfix слушает только loopback).
# В dev: можно использовать Mailhog/Mailtrap/reg.ru — для этого укажи host/user/password.
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Kids CEO <noreply@kids-ceo.ru>"
# Необязательно: email, куда дублировать уведомления о каждой оплате
ADMIN_NOTIFY_EMAIL=

# ===== English Lessons =====
# Ссылка на папку Google Drive с материалами курса (шлётся в письме клиенту)
ENGLISH_LESSONS_MATERIALS_URL=https://drive.google.com/drive/folders/1_guTloxL7jrMS-Oxl_ftQg4we-ShEAQS?usp=sharing
